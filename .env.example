DISCORD_TOKEN=your_discord_bot_token
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token
PLEX_LIBRARY_NAME=Films
ALLOWED_CHANNEL_ID=0

# Unraid paths (defaults should work for most setups)
USER_SHARE_BASE=/mnt/user
CACHE_BASE=/mnt/cache

# Plex Docker path translation (only needed if Plex runs in Docker
# with a different internal path mapping)
# Example: Plex container maps /mnt/user/Media -> /data
#   PLEX_PATH_PREFIX=/data
#   PLEX_PATH_REPLACE=/mnt/user/Media
PLEX_PATH_PREFIX=
PLEX_PATH_REPLACE=
